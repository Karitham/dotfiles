# Kubectl
alias -g k="kubectl"
alias -g kply="kubectl apply -f"

# Ls
alias -g ll="ls --color=auto -lha"

# Cat
alias -g cat='bat -pp'

# Kitty
alias ssh='kitty +kitten ssh'

# Paths
alias ..='cd ..'
alias ...='cd ../..'

# Go
alias g="go"
alias gr="g run "
alias gt="g test "

# Zig
alias zbt="zig build test"
alias zbr="zig build run"

# Git
alias gc="git commit -a -S"
alias gs="git status"
alias gds="git diff --stat"

# Vim
alias v=nvim

# Vagrant ssh fix with kitty
alias vagrant="TERM=xterm-256color vagrant"
alias vag=vagrant

# Docker compose
alias dc='docker compose'
