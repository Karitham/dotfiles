configuration {
	modi: "window,run,ssh";
  font: "FiraCode Nerd Font 14";
  combi-modi: "window,drun,ssh";
  timeout {
      action: "kb-cancel";
      delay:  0;
  }
  filebrowser {
      directories-first: true;
      sorting-method:    "name";
  }
}

@theme "/usr/share/rofi/themes/glue_pro_blue.rasi"
